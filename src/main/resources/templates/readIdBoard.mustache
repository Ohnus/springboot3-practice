<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Board</title>
</head>
<body>
{{BOARD.title}}

{{BOARD.content}}

<form action="/board/read" method="get">
    <input type="submit" value="글 목록이동" />
